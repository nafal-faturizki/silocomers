{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@silocomers/*": ["packages/*/src"]
    }
  },
  "include": ["packages/**/src", "apps/**/src"],
  "exclude": ["node_modules", "dist"]
}
